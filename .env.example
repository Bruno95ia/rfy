# Supabase (Auth + API). Para dev 100% local use Supabase local (veja abaixo).
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=seu-anon-key

# Supabase Service Role - SOMENTE no servidor, NUNCA no client
SUPABASE_SERVICE_ROLE_KEY=seu-service-role-key

# --- Dev local: Postgres Docker (5432) + Supabase local (só Auth) ---
# npm run supabase:local sobe Postgres (Docker), Supabase (Auth), aplica migrations e mostra as linhas abaixo.
# Use Postgres na porta 5432 para dados; Supabase local só para login.
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres
# AI_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres
# + NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY do "npx supabase status"

# Criptografia de secrets (api_key, webhook_secret). 64 chars hex ou qualquer string >= 16 chars
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=

# Rate limit (opcional). Crie em upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Inngest (opcional para dev local)
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# App URL (para redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Postgres no Docker local (recomendado para dev) ---
# Suba o container: npm run db:up (ou docker compose up -d postgres)
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
AI_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# --- Conta e base de demonstração ---
# Crie a conta Admin (admin@demo.rfy.local / Adminrv) e a base demo: npm run db:seed:admin
# Requer NEXT_PUBLIC_SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY e DATABASE_URL (ou AI_DATABASE_URL).
# Na app, em Configurações, use "Zerar e recarregar base de demonstração" para resetar a base demo.

# AI Service (Next.js usa para proxy das rotas /api/ai/*)
AI_SERVICE_URL=http://localhost:8001

# Porta de host do MLflow (container usa 5000 internamente)
MLFLOW_HOST_PORT=5001
# Backend store do MLflow (default local para dev)
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow/artifacts/mlflow.db

# AI Service - proteção do endpoint /train (produção)
# Se definido, POST /train exige header X-Train-API-Key com este valor
# AI_TRAIN_SECRET=

# AI Service - CORS em produção (opcional)
# Ex: https://app.seudominio.com ou lista separada por vírgula
# AI_CORS_ORIGINS=*

# --- E-mail (Resend) - alertas e convites ---
# Crie conta em resend.com e use a API key. Sem isso, alertas e convites por e-mail não são enviados.
# RESEND_API_KEY=
# ALERT_FROM_EMAIL=noreply@seudominio.com
# ALERT_FROM_NAME=RFY Alertas
# INVITE_FROM_EMAIL=convites@seudominio.com
# INVITE_FROM_NAME=RFY Convites

# --- Google AI (opcional, para features de IA além do forecast) ---
# GOOGLE_AI_API_KEY=
