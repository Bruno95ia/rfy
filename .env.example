# RFY roda com auth própria via cookie + PostgreSQL.
# Para desenvolvimento local, basta configurar banco, AI service e um diretório de uploads.

# App URL (redirects, links e convites)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL principal
# Local: postgresql://postgres:postgres@localhost:5432/postgres
# Cloud: use a connection string completa do seu provedor
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# AI service usa AI_DATABASE_URL quando definido; se vazio, faz fallback para DATABASE_URL
AI_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
AI_SERVICE_URL=http://localhost:8001

# Overrides opcionais só para Docker Compose.
# Se não definir, o compose usa o Postgres interno em postgres:5432.
# COMPOSE_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres
# COMPOSE_AI_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres

# Uploads sem Supabase Storage: salvar em disco local
UPLOAD_DIR=.uploads

# Criptografia de secrets (api_key, webhook_secret).
# Em produção gere com: openssl rand -hex 32
ENCRYPTION_KEY=rfy-local-dev-encryption-key-change-me

# AI service
# Em Docker, sobrescreva AI_ARTIFACTS_PATH para /artifacts
AI_ARTIFACTS_PATH=ai-service/artifacts
AI_K_ANONYMITY=5
# AI_TRAIN_SECRET=
# AI_CORS_ORIGINS=*
# AI_DEBUG=true

# Porta de host do MLflow (container usa 5000 internamente)
MLFLOW_HOST_PORT=5001
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow/artifacts/mlflow.db

# Rate limit (opcional). Crie em upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Inngest (opcional para dev local)
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# E-mail (opcional). Sem isso, alertas e convites por e-mail não são enviados.
# RESEND_API_KEY=
# ALERT_FROM_EMAIL=noreply@seudominio.com
# ALERT_FROM_NAME=RFY Alertas
# INVITE_FROM_EMAIL=convites@seudominio.com
# INVITE_FROM_NAME=RFY Convites

# Google AI (opcional, para recursos adicionais além do forecast)
# GOOGLE_AI_API_KEY=

# Supabase é opcional e hoje serve apenas para fluxos legados/externos.
# Não é necessário para login/signup padrão da aplicação.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
